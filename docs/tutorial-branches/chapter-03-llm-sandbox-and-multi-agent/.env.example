# =============================================================================
# LLM API KEYS AND CONFIGURATION
# =============================================================================

# -----------------------------------------------------------------------------
# OPTION 1: Internal/Local LLM Provider (OpenAI-Compatible Format)
# -----------------------------------------------------------------------------
# Use this pattern for internal LLM providers that expose OpenAI-compatible APIs.
# Uncomment and configure the following when using an internal provider:
# 
# IMPORTANT: BASE_URL should be the base domain without /v1 or endpoint paths
# The framework will automatically construct the correct endpoint paths:
#   - For chat: {BASE_URL}/chat/completions
#   - For embeddings: {BASE_URL}/embeddings

INTERNAL_LLM_API_KEY="your-internal-api-key"
INTERNAL_LLM_BASE_URL="https://your-internal-llm.example.com"
INTERNAL_LLM_MODEL="your-model-name"              # e.g., "gpt-4-compatible-model"
INTERNAL_LLM_EMBEDDING_MODEL="your-embedding-model" # e.g., "text-embedding-model"

# -----------------------------------------------------------------------------
# OPTION 2: Cloud Provider Configuration (Azure OpenAI, OpenAI, etc.)
# -----------------------------------------------------------------------------

# --- Default/Fallback LLM Configuration ---
#DEFAULT_LLM_MODEL="o3-mini" # Fallback model if no purpose-specific model is set

# --- Azure OpenAI Configuration ---
# Used for Azure-hosted OpenAI models
#AZURE_API_KEY="zzz" # TODO: Add your own. Required for Azure models
#AZURE_API_BASE="zzz"
#AZURE_API_VERSION="zzz"

# --- OpenAI Configuration ---
# Direct OpenAI API access
# OPENAI_API_KEY="sk-your_openai_api_key"

# --- Anthropic Configuration ---
# ANTHROPIC_API_KEY="sk-ant-your_anthropic_api_key"

# --- Google Vertex AI Configuration ---
# VERTEXAI_PROJECT="your_gcp_project_id"
# VERTEXAI_LOCATION="your_gcp_region" # e.g., us-central1

# --- Amazon Bedrock Configuration ---
# Requires AWS credentials configured via env vars or AWS config
# AWS_ACCESS_KEY_ID="your_aws_access_key_id"
# AWS_SECRET_ACCESS_KEY="your_aws_secret_access_key"
# AWS_REGION_NAME="your_aws_region" # e.g., us-east-1

# --- Local Ollama Configuration ---
# For running local open-source models via Ollama
# OLLAMA_API_BASE="zzz"
# OLLAMA_API_BASE_URL="zzz" # Alternative naming for compatibility

# --- Groq Configuration ---
# GROQ_API_KEY="pk-your_groq_api_key"

# -----------------------------------------------------------------------------
# Purpose-Specific LLM Configuration
# -----------------------------------------------------------------------------

# --- LangChain Agent Configuration ---
# Model used by LangChain components (e.g., ScientificWorkflowAgent)
LANGCHAIN_LLM_MODEL="o3-mini"

# --- Streamlit UI Configuration ---
STREAMLIT_DEFAULT_MODEL="o3-mini"
# STREAMLIT_AZURE_API_KEY="..."
# STREAMLIT_AZURE_API_BASE="..."
# STREAMLIT_AZURE_API_VERSION="..."
# STREAMLIT_OPENAI_API_KEY="..."
# STREAMLIT_OLLAMA_API_BASE="..."

# --- Embedding Model Configuration ---
# EMBEDDING_DEFAULT_MODEL="text-embedding-3-large"
# EMBEDDING_AZURE_API_KEY="zzz" # TODO: Add your own
# EMBEDDING_AZURE_API_BASE="https://aqe-ldrd-openai.openai.azure.com/openai/deployments/text-embedding-3-large/embeddings?api-version=2023-05-15"
# EMBEDDING_AZURE_API_VERSION="2023-05-15"
# EMBEDDING_OPENAI_API_KEY="..."
# EMBEDDING_OLLAMA_API_BASE="..."

# --- RAG (Retrieval-Augmented Generation) Configuration ---
# RAG_DEFAULT_MODEL="o3-mini"
# RAG_AZURE_API_KEY="..."
# RAG_AZURE_API_BASE="..."
# RAG_AZURE_API_VERSION="..."
# RAG_OPENAI_API_KEY="..."
# RAG_OLLAMA_API_BASE="..."

# --- NVIDIA API Configuration ---
# For multi-modal document analysis
# NVIDIA_MODEL="nvidia/llama-3.1-nemotron-nano-vl-8b-v1"
# NVIDIA_API_KEY="nvapi-zzzz" # TODO: Add your own
# NVIDIA_API_BASE_URL="https://integrate.api.nvidia.com/v1"
# RAG_NVIDIA_API_VERSION="2024-01-01"

# =============================================================================
# MCP SERVER CONFIGURATION
# =============================================================================

MCP_SERVER_HOST="0.0.0.0"
MCP_SERVER_PORT="8080"
UVICORN_WORKERS="2" # For SQLite, start with 1 worker

# =============================================================================
# STREAMLIT CONFIGURATION
# =============================================================================

STREAMLIT_SERVER_PORT="8501"
STREAMLIT_SERVER_ADDRESS="0.0.0.0"

# =============================================================================
# SERVICE URLS (Docker Compose)
# =============================================================================
# These are used by services to communicate with each other.
# For Docker Compose, use container names. For local runs, change to `localhost`.
# Kubernetes deployments override these automatically.

DEFAULT_MCP_SERVER_URL="http://mcp_server:8080/mcp"
HPC_MCP_SERVER_URL="http://hpc_mcp_server:8081/mcp"
SANDBOX_MCP_SERVER_URL="http://sandbox_mcp_server:8082/mcp"

# =============================================================================
# HPC MCP SERVER CONFIGURATION
# =============================================================================

HPC_MCP_SERVER_HOST="0.0.0.0"
HPC_MCP_SERVER_PORT="8081"
HPC_UVICORN_WORKERS="1"

# =============================================================================
# CHROMADB CONFIGURATION
# =============================================================================
# Path for ChromaDB persistent storage.
# Use ":memory:" for ephemeral (data lost on restart).

CHROMA_DB_PATH="./data/persistent_chroma_db"
# CHROMA_DB_PATH=":memory:"

# =============================================================================
# DATABASE CONFIGURATION (DEPRECATED - use ChromaDB)
# =============================================================================

DATABASE_URL="sqlite+aiosqlite:///./data/mcp_state.db"

# =============================================================================
# FILE STORAGE CONFIGURATION
# =============================================================================

SHARED_UPLOAD_DIR="./data/uploaded_files"

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================

LOGGING_LEVEL="DEBUG" # Options: DEBUG, INFO, WARNING, ERROR

