# GITLAB_INSTANCE_URL="https://tanuki.pnnl.gov"
# GITLAB_PROJECT_ID="your_gitlab_project_id"
# GITLAB_PROJECT_NAME="your_gitlab_project_name"

# =============================================================================
# GITHUB INTEGRATION CONFIGURATION
# =============================================================================

# GH_ACCESS_TOKEN_GITXRAY="ghp_zzzz" # TODO: Add your own. Required for GitXRay

# =============================================================================
# WEB SEARCH CONFIGURATION
# =============================================================================
# API keys for various web search providers used by WebSearchAgent

# BRAVE_SEARCH_API_KEY="YOUR_BRAVE_API_KEY_HERE" # TODO: Add your own
# BRAVE_SEARCH_API_BASE="https://api.brave.com/search/v1"

# GOOGLE_SEARCH_API_KEY="YOUR_GOOGLE_API_KEY_HERE" # TODO: Add your own
# GOOGLE_SEARCH_CX="YOUR_GOOGLE_CX_HERE" # Custom Search Engine ID
# GOOGLE_SEARCH_API_BASE="https://www.googleapis.com/customsearch/v1"

# BING_SEARCH_API_KEY="YOUR_BING_API_KEY_HERE" # TODO: Add your own
# BING_SEARCH_API_BASE="https://api.bing.microsoft.com/v7.0/search"

# DUCKDUCKGO_SEARCH_API_BASE="https://api.duckduckgo.com"
# DUCKDUCKGO_SEARCH_API_KEY="YOUR_DUCKDUCKGO_API_KEY_HERE" # TODO: Add your own

# =============================================================================
# HPC CLUSTER SSH CONFIGURATION
# =============================================================================
# Configuration for connecting to remote HPC clusters via SSH

HPC_HOST="hpc.institution.edu"          # HPC cluster hostname or IP
HPC_USER="your_username"                 # SSH username
HPC_SSH_PORT=22                          # SSH port (default: 22)

#--- SSH Authentication (Choose ONE method) ---

# Option 1: SSH Key Authentication (RECOMMENDED)
# HPC_SSH_KEY_PATH_HOST: Path to SSH key on YOUR LOCAL MACHINE (host)
#   This file will be mounted into the Docker container at /home/appuser/.ssh/hpc_key
HPC_SSH_KEY_PATH_HOST="/Users/yourusername/.ssh/your_hpc_key.pem"  # Path on HOST machine
# HPC_SSH_KEY_PASSPHRASE=""              # Optional: passphrase if key is encrypted

# Option 2: Password Authentication (NOT RECOMMENDED - use SSH keys instead)
# HPC_SSH_PASSWORD="your_password"

# --- Optional: Slurm Configuration ---
# HPC_DEFAULT_PARTITION="compute"         # Default Slurm partition/queue
# HPC_DEFAULT_WALLTIME="01:00:00"         # Default job time limit
# HPC_DEFAULT_WORK_DIR="/home/user/jobs"  # Default directory for job scripts

# --- NCBI BLAST Contact Info ---
# NCBI requires a contact email for automated BLAST queries (policy: https://www.ncbi.nlm.nih.gov/books/NBK153387/)
# Replace with your own email address before deploying publicly.
NCBI_CONTACT_EMAIL="your-email@institution.edu"

